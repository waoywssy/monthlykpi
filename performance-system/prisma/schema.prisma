generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  teams     Team[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Team {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  @@unique([name, departmentId])
}

model Employee {
  id           String              @id @default(cuid())
  name         String              @unique
  role         String?
  sortOrder    Int                 @default(999)
  isRegular    Boolean             @default(true)
  salary       Float?              @default(0)
  teamId       String
  team         Team                @relation(fields: [teamId], references: [id])
  managerId    String?
  manager      Employee?           @relation("ManagerToEmployee", fields: [managerId], references: [id])
  subordinates Employee[]          @relation("ManagerToEmployee")
  evaluations  EvaluationRecord[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model EvaluationRecord {
  id            String      @id @default(cuid())
  employeeId    String
  employee      Employee    @relation(fields: [employeeId], references: [id])
  period        String      
  
  selfEvaluationText    String? 
  managerEvaluationText String? 
  
  selfTotal     Float       
  managerTotal  Float       
  finalScore    Float       
  rating        String?     
  
  scores        ScoreItem[]
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  @@unique([employeeId, period])
}

model ScoreItem {
  id                 String           @id @default(cuid())
  evaluationRecordId String
  evaluationRecord   EvaluationRecord @relation(fields: [evaluationRecordId], references: [id], onDelete: Cascade)
  
  category           String           
  name               String           
  weight             Float            
  selfScore          Float            
  managerScore       Float            

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}
model Project {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  clientName  String?
  totalAmount Float        @default(0)
  status      String       @default("IN_PROGRESS") // e.g., IN_PROGRESS, COMPLETED, CANCELLED
  collections Collection[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Collection {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  amount       Float
  date         DateTime
  period       String   // e.g., "2026-03"
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
